<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventory Management</title>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <!-- AG Grid -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.4/styles/ag-grid.min.css">
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.4/styles/ag-theme-alpine.min.css">
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.4/dist/ag-grid-community.min.js"></script>
    <script src="https://unpkg.com/ag-charts-community@31.3.2/dist/ag-charts-community.min.js"></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/Layout.css" />
</head>

<body>

    @if (!string.IsNullOrEmpty(Context.Session.GetString("Username")))
    {
        <!-- TOP NAVBAR - FIXED -->
        <nav class="top-navbar fixed-navbar">
            <div class="project-name">
                <i class="bi bi-box-seam-fill"></i>
                Inventory Management System
            </div>
            <div class="nav-right">
                <span class="user-greeting">
                    <i class="bi bi-person-circle"></i>
                    @Context.Session.GetString("Username")
                </span>
                <a href="@Url.Action("Logout", "Account")" class="logout-btn">
                    <i class="bi bi-box-arrow-right"></i>
                    Logout
                </a>
            </div>
        </nav>
    }

    <div class="dashboard-container">
        @if (!string.IsNullOrEmpty(Context.Session.GetString("Username")))
        {
            <!-- SIDEBAR - FIXED -->
            <aside class="sidebar fixed-sidebar">
                <div class="sidebar-logo">
                    <div class="logo-icon">
                        <i class="bi bi-boxes"></i>
                    </div>
                    <div class="logo-text">
                        Inventory
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="@Url.Action("Index", "Dashboard")">
                        <i class="bi bi-grid-1x2-fill"></i>
                        Dashboard
                    </a>
                    <a href="@Url.Action("Index", "Category")">
                        <i class="bi bi-bookmark-fill"></i>
                        Categories
                    </a>
                    <a href="@Url.Action("Index", "Product")">
                        <i class="bi bi-box-fill"></i>
                        Products
                    </a>

                    @{
                        var role = Context.Session.GetString("Role");
                        if (role == "1" || role == "3")
                        {
                            <a href="@Url.Action("Create", "Stock")">
                                <i class="bi bi-arrow-left-right"></i>
                                New Transaction
                            </a>
                        }
                    }
                    <a href="@Url.Action("Index", "Stock")">
                        <i class="bi bi-receipt-cutoff"></i>
                        Transaction History
                    </a>

                    @if (Context.Session.GetString("Role") == "1")
                    {
                        <a href="@Url.Action("InventoryAccess", "Account")">
                            <i class="bi bi-shield-lock-fill"></i>
                            Inventory Access
                        </a>
                    }
                </nav>
            </aside>
        }

        <!-- MAIN CONTENT WITH OFFSET -->
        <main class="main-content offset-content">
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>