@model CategoryModel
@{
    ViewData["Title"] = "Add Category";
}
<h2>Add Category</h2>
@if (ViewBag.Success != null)
{
    <div class="alert alert-success">
        @ViewBag.Success
    </div>
}

<div asp-validation-summary="All" class="alert alert-danger"></div>
<form method="post">
    <div class="form-group">
        <label asp-for="CategoryName"></label>
        <input asp-for="CategoryName" />
        <span asp-validation-for="CategoryName"></span>
    </div>
    <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
        <label asp-for="IsActive" style="margin-bottom: 0;"></label>
        <input asp-for="IsActive" type="checkbox" style="width: auto; margin: 0;" />
        <span asp-validation-for="IsActive"></span>
    </div>
    <button type="submit" class="btn btn-success">Save</button>
    <a href="@Url.Action("Index")" class="btn btn-primary">Cancel</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}