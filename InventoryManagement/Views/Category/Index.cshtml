@{
    ViewData["Title"] = "Categories";
}

<style>
    /* Action buttons inside grid (Edit / Delete) */
    .grid-action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 6px 16px;
        min-width: 80px;
        height: 32px;
        font-size: 13px;
        font-weight: 500;
        line-height: 1;
        font-family: inherit;
        text-align: center;
        border-radius: 30px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
        margin: 0 4px;
        box-sizing: border-box;
    }
    .grid-action-btn.edit-btn {
        background-color: #28a745;
        color: white;
    }
    .grid-action-btn.delete-btn {
        background-color: #dc3545;
        color: white;
    }
    .grid-action-btn:hover {
        transform: translateY(-1px);
        filter: brightness(0.92);
    }
    a.grid-action-btn,
    button.grid-action-btn {
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
    }
    /* Center the action column content */
    .ag-cell[col-id="actions"] {
        display: flex !important;
        justify-content: center !important;
        align-items: center !important;
    }

    /* Circular plus button */
    .btn-add-category-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background-color: #28a745;
        color: white;
        font-size: 24px;
        font-weight: bold;
        border-radius: 50%;
        text-decoration: none;
        transition: 0.2s;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }
    .btn-add-category-icon:hover {
        background-color: #218838;
        transform: scale(1.05);
        text-decoration: none;
        color: white;
    }

    /* Export Button Style */
    .btn-export {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background-color: #28a745;
        color: white;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 500;
        font-size: 14px;
        transition: 0.2s;
        border: none;
        cursor: pointer;
    }
    .btn-export:hover {
        background-color: #218838;
        text-decoration: none;
        color: white;
        transform: scale(1.02);
    }

    /* Top bar: heading left, buttons right */
    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 10px;
    }
    .plus-wrapper {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Hide action column for normal user */
    .hide-actions .ag-cell[col-id="actions"] {
        display: none !important;
    }
</style>

<input type="hidden" id="role" value="@Context.Session.GetString("Role")" />

<div class="container mt-4">
    <!-- Single Top Bar with Export CSV on Right -->
    <div class="top-bar">
        <h2>📂 Categories</h2>
        <div class="plus-wrapper">
            <!-- Export CSV Button (Right Side) -->
            <a href="@Url.Action("ExportCsv")" class="btn-export">
                📥 Export CSV
            </a>
            
            @{
                var role = Context.Session.GetString("Role");
                if (role == "1" || role == "3")
                {
                    <a href="@Url.Action("Create")" class="btn-add-category-icon" title="Add New Category">+</a>
                }
                else
                {
                    <span style="font-size: 14px; color: #6c757d; font-weight: 500;">🔒 Access Denied</span>
                }
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div id="categoryGrid" style="height: 500px; width: 100%;" class="ag-theme-alpine"></div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.2/dist/ag-grid-community.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.2/styles/ag-grid.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.2/styles/ag-theme-alpine.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        // ✅ Action Cell Renderer – Hide Edit/Delete for Normal User
        class ActionCellRenderer {
            init(params) {
                try {
                    const categoryId = params.data.categoryId;
                    const role = document.getElementById("role").value;
                    const container = document.createElement('div');
                    container.style.display = 'flex';
                    container.style.justifyContent = 'center';
                    container.style.alignItems = 'center';
                    container.style.gap = '8px';

                    const isNormalUser = (role == "2");

                    // ---------- Edit Button ----------
                    const editBtn = document.createElement('a');
                    editBtn.className = 'grid-action-btn edit-btn';
                    editBtn.innerHTML = '✏️ Edit';

                    if (!isNormalUser) {
                        editBtn.href = `/Category/Edit/${categoryId}`;
                    } else {
                        editBtn.style.display = 'none';
                    }

                    // ---------- Delete Button ----------
                    const deleteBtn = document.createElement('button');
                    deleteBtn.className = 'grid-action-btn delete-btn';
                    deleteBtn.innerHTML = '🗑️ Delete';

                    if (!isNormalUser) {
                        deleteBtn.onclick = () => {
                            if (confirm('Are you sure you want to delete this category?')) {
                                $.ajax({
                                    url: '/Category/Delete',
                                    type: 'POST',
                                    data: { id: categoryId },
                                    success: (res) => {
                                        try {
                                            if (res.success) {
                                                alert(res.message);
                                                loadGridData();
                                            } else {
                                                alert(res.message);
                                            }
                                        } catch (ajaxError) {
                                            console.error('Error in delete response:', ajaxError);
                                            alert('Error processing delete response.');
                                        }
                                    },
                                    error: (xhr, status, error) => {
                                        console.error('Delete AJAX error:', error);
                                        alert('Error deleting category. Please try again.');
                                    }
                                });
                            }
                        };
                    } else {
                        deleteBtn.style.display = 'none';
                    }

                    container.appendChild(editBtn);
                    container.appendChild(deleteBtn);
                    this.eGui = container;
                } catch (error) {
                    console.error('Error in ActionCellRenderer:', error);
                }
            }
            getGui() {
                return this.eGui;
            }
        }

        const columnDefs = [
            { 
                headerName: "Category Name", 
                field: "categoryName", 
                floatingFilter: true, 
                filter: 'agTextColumnFilter',
                sortable: true, 
                flex: 2,
                filterParams: { caseSensitive: false, filterOptions: ['contains'] }
            },
            { 
                headerName: "Status", 
                field: "isActive", 
                sortable: true, 
                floatingFilter: true, 
                filter: 'agTextColumnFilter',
                width: 120,
                cellRenderer: (params) => {
                    try {
                        return params.value ? "Active" : "Inactive";
                    } catch (error) {
                        console.error('Status render error:', error);
                        return 'Unknown';
                    }
                },
                filterParams: { caseSensitive: false, filterOptions: ['contains'] }
            },
            { 
                headerName: "Created Date", 
                field: "createdDate", 
                sortable: true, 
                floatingFilter: true, 
                filter: 'agDateColumnFilter',
                width: 150,
                valueFormatter: (params) => {
                    try {
                        return params.value ? new Date(params.value).toLocaleDateString() : '';
                    } catch (error) {
                        console.error('Date formatter error:', error);
                        return '';
                    }
                }
            },
            { 
                headerName: "Actions", 
                field: "actions",
                cellRenderer: ActionCellRenderer, 
                pinned: 'right', 
                width: 190, 
                sortable: false, 
                filter: false
            }
        ];

        const gridOptions = {
            columnDefs,
            defaultColDef: { sortable: true, filter: true, resizable: true },
            pagination: false,
            rowSelection: 'single',
            animateRows: true,
            onGridReady: (params) => {
                try {
                    params.api.sizeColumnsToFit();
                } catch (error) {
                    console.error('Grid ready error:', error);
                }
            }
        };

        // Helper: get URL parameter by name
        function getUrlValue(name) {
            try {
                const urlParams = new URLSearchParams(window.location.search);
                return urlParams.get(name);
            } catch (error) {
                console.error('Error getting URL parameter:', error);
                return null;
            }
        }

        function loadGridData() {
            try {
                $.ajax({
                    url: '/Category/GetCategories',
                    type: 'GET',
                    dataType: 'json',
                    success: function(response) {
                        try {
                            if (response.success && response.data) {
                                gridOptions.api.setRowData(response.data);
                                
                                const searchValue = getUrlValue("search") || getUrlValue("categoryName");
                                if (searchValue) {
                                    gridOptions.api.setFilterModel({
                                        categoryName: {
                                            filterType: 'text',
                                            type: 'contains',
                                            filter: searchValue
                                        }
                                    });
                                    gridOptions.api.onFilterChanged();
                                }
                            } else {
                                alert('Failed to load categories: ' + (response.message || 'Unknown error'));
                            }
                        } catch (error) {
                            console.error('Error processing response:', error);
                            alert('Error loading categories.');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('AJAX error:', error);
                        console.error('Status:', status);
                        console.error('Response:', xhr.responseText);
                        alert('Error loading categories. Please check console for details.');
                    }
                });
            } catch (error) {
                console.error('Error in loadGridData:', error);
                alert('Error loading categories.');
            }
        }

        $(document).ready(function() {
            try {
                const gridDiv = document.querySelector('#categoryGrid');
                if (gridDiv) {
                    new agGrid.Grid(gridDiv, gridOptions);
                    loadGridData();
                } else {
                    console.error('Grid container not found.');
                }
            } catch (error) {
                console.error('Error initializing grid:', error);
                alert('Error loading categories grid.');
            }
        });
    </script>
}