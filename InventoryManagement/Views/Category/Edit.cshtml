@model CategoryModel
@{
    ViewData["Title"] = "Edit Category";
}
<h2>Edit Category</h2>
<form method="post">
    <input type="hidden" asp-for="CategoryId" />
    <div class="form-group">
        <label asp-for="CategoryName"></label>
        <input asp-for="CategoryName" />
        <span asp-validation-for="CategoryName"></span>
    </div>
    <div class="form-group">
        <label asp-for="Description"></label>

        <input asp-for="Description"
               class="form-control" />

        <span asp-validation-for="Description"></span>
    </div>

    <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
        <label asp-for="IsActive" style="margin-bottom: 0;"></label>
        <input asp-for="IsActive" type="checkbox" style="width: auto; margin: 0;" />
        <span asp-validation-for="IsActive"></span>
    </div>
    <button type="submit" class="btn btn-success">Update</button>
    <a href="@Url.Action("Index")" class="btn btn-primary">Cancel</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}